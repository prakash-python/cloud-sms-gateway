<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020617"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:id="@+id/statusIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="24dp"
        android:src="@android:drawable/ic_dialog_email"
        app:tint="#2563eb" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CloudSMS Gateway"
        android:textColor="#ffffff"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Status: Disconnected"
        android:textColor="#94a3b8"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:background="#1e293b"
        android:orientation="vertical"
        android:padding="20dp"
        android:backgroundTint="#0f172a">
        
        <TextView
            android:id="@+id/deviceIdText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device ID: Loading..."
            android:textColor="#cbd5e1"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/serverUrlText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Server: Connecting..."
            android:textColor="#64748b"
            android:textSize="11sp" />
    </LinearLayout>

    <Button
        android:id="@+id/reconnectButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="RECONNECT NOW"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:backgroundTint="#2563eb" />

</LinearLayout>
